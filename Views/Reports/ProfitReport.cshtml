@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Profit Report";
    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;
}

<div class="container-fluid mt-3">
    <h2><i class="fas fa-dollar-sign"></i> Profit Report</h2>

    <form method="get" class="mb-3 row g-2" id="filterForm">
        <div class="col-auto">
            <label>From:</label>
            <input type="date" name="startDate" value="@startDate" class="form-control" />
        </div>
        <div class="col-auto">
            <label>To:</label>
            <input type="date" name="endDate" value="@endDate" class="form-control" />
        </div>
        <div class="col-auto align-self-end">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a href="/Reports/ProfitReport" class="btn btn-secondary">Reset</a>
        </div>
    </form>

    <div id="dynamicContent">
        @await Html.PartialAsync("_ProfitReportPartial")
    </div>
</div>

@section Scripts {
    <script>
        function refreshReport() {
            var formData = $('#filterForm').serialize();
            $.get('/Reports/RefreshProfitReport?' + formData, function(data) {
                $('#dynamicContent').html(data);
            }).fail(function() { console.log('Auto-refresh failed'); });
        }
        setInterval(refreshReport, 30000);
    </script>
}