@model IEnumerable<POSERP.Models.Reports.InventoryReportViewModel>

@if (!Model.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Barcode</th>
                    <th>Current Stock</th>
                    <th>Reorder Level</th>
                    <th>Cost Price</th>
                    <th>Selling Price</th>
                    <th>Last 30 Days Sold</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string statusClass = item.Status == "Out of Stock" ? "bg-danger" : (item.Status == "Low Stock" ? "bg-warning" : "bg-success");
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Barcode</td>
                        <td>@item.CurrentStock</td>
                        <td>@item.ReorderLevel</td>
                        <td>$@item.CostPrice.ToString("F2")</td>
                        <td>$@item.SellingPrice.ToString("F2")</td>
                        <td>@item.TotalSold</td>
                        <td><span class="badge @statusClass">@item.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}