@{
    var summary = ViewBag.Summary as POSERP.Models.Reports.ProfitSummaryViewModel ?? new POSERP.Models.Reports.ProfitSummaryViewModel();
    var monthly = ViewBag.MonthlyProfits as List<dynamic> ?? new List<dynamic>();
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Summary</div>
            <div class="card-body">
                <p><strong>Total Sales:</strong> $@summary.TotalSales.ToString("F2")</p>
                <p><strong>Total Cost:</strong> $@summary.TotalCost.ToString("F2")</p>
                <p><strong>Gross Profit:</strong> $@summary.GrossProfit.ToString("F2")</p>
                <p><strong>Profit Margin:</strong> @summary.ProfitMargin.ToString("F2")%</p>
                <p><strong>Total Discount:</strong> $@summary.TotalDiscount.ToString("F2")</p>
                <p><strong>Total Tax:</strong> $@summary.TotalTax.ToString("F2")</p>
                <p><strong>Net Profit:</strong> $@summary.NetProfit.ToString("F2")</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Monthly Profit Trend</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Sales</th>
                                <th>Cost</th>
                                <th>Profit</th>
                                <th>Margin</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in monthly)
                            {
                                <tr>
                                    <td>@m.YearMonth</td>
                                    <td>$@m.Sales.ToString("F2")</td>
                                    <td>$@m.Cost.ToString("F2")</td>
                                    <td>$@m.Profit.ToString("F2")</td>
                                    <td>@m.Margin.ToString("F2")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>