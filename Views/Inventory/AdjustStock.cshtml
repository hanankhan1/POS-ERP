@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Adjust Stock";
    var product = Model as dynamic;
}

<div class="container">
    <h2 class="mt-3">Adjust Stock for @product.ProductName</h2>
    <div class="card">
        <div class="card-body">
            <form method="post" action="/Inventory/AdjustStock/@product.ProductID">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label>Current Stock</label>
                    <input type="number" class="form-control" value="@product.CurrentStock" disabled />
                </div>
                <div class="mb-3">
                    <label>New Quantity</label>
                    <input type="number" name="newQuantity" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label>Reason for Adjustment</label>
                    <textarea name="reason" class="form-control" rows="2" placeholder="e.g., Inventory count, damaged goods, etc."></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Save Adjustment</button>
                <a href="/Inventory/StockLevels" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>