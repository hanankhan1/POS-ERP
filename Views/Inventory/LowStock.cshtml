@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Low Stock Report";
    var lowStock = Model as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="container">
    <h2 class="mt-3"><i class="fas fa-exclamation-triangle me-2"></i>Low Stock Products</h2>

    @if (!lowStock.Any())
    {
        <div class="alert alert-success mt-3">✅ No low stock products. All inventory levels are healthy.</div>
    }
    else
    {
        <div class="card mt-3">
            <div class="card-body">
                <table class="table table-warning table-bordered">
                    <thead>
                        <tr>
                            <th>Product</th><th>Barcode</th><th>Current Stock</th><th>Reorder Level</th>
                            <th>Supplier</th><th>Contact</th><th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in lowStock)
                        {
                            <tr>
                                <td>@item.ProductName</td
                                <td>@item.Barcode</td
                                <td>@item.QuantityInStock</td
                                <td>@item.ReorderLevel</td
                                <td>@item.SupplierName</td
                                <td>@item.SupplierPhone</td
                                <td><a href="/Purchase/Create?productId=@item.ProductID" class="btn btn-sm btn-primary">Create PO</a></td
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>