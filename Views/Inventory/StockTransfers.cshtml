@using POSERP.Models.ViewModels
@model List<StockTransferViewModel>
@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Stock Transfers";
}

<div class="container-fluid px-4 py-3">
    <div class="inventory-header">
        <h2><i class="fas fa-exchange-alt me-2"></i>Stock Transfers</h2>
        <p class="mb-0 opacity-75">Transfer stock between warehouse locations</p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>New Stock Transfer</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="CreateTransfer">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Product</label>
                        <select name="productId" class="form-select" asp-items="ViewBag.Products" required>
                            <option value="">Select Product</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">From Location</label>
                        <select name="fromLocation" class="form-select" asp-items="ViewBag.Locations" required></select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">To Location</label>
                        <select name="toLocation" class="form-select" asp-items="ViewBag.Locations" required></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Quantity</label>
                        <input name="quantity" type="number" class="form-control" placeholder="Qty" required min="1" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Notes</label>
                        <input name="notes" class="form-control" placeholder="Additional details (optional)" />
                    </div>
                    <div class="col-md-12 mt-3">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Create Transfer</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Transfer History</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Actions</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var transfer in Model)
                            {
                                <tr>
                                    <td>@(transfer.TransferDate.ToString("MM/dd/yyyy HH:mm"))</td>
                                    <td><strong>@(transfer.ProductName ?? "")</strong></td>
                                    <td>@(transfer.FromLocation ?? "")</td>
                                    <td>@(transfer.ToLocation ?? "")</td>
                                    <td>@transfer.Quantity</td>
                                    <td>
                                        @if (transfer.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                    </td>
                                    <td>
                                        @if (transfer.Status == "Pending")
                                        {
                                            <form method="post" asp-action="ApproveTransfer" style="display:inline;">
                                                <input type="hidden" name="transferId" value="@transfer.TransferId" />
                                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Approve this transfer?');">
                                                    <i class="fas fa-check"></i> Approve
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Completed</span>
                                        }
                                    </td>
                                    <td>@(transfer.Notes ?? "")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="fas fa-exchange-alt fa-2x mb-2 d-block"></i>
                                    No stock transfers yet. Create your first transfer above.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .inventory-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        padding: 1.5rem 2rem;
        border-radius: 1rem;
        color: white;
        margin-bottom: 2rem;
    }
</style>

@if (TempData["Success"] != null)
{
    <script>alert('@TempData["Success"]');</script>
}
@if (TempData["Error"] != null)
{
    <script>alert('Error: @TempData["Error"]');</script>
}