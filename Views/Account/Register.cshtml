@model POSERP.Models.Account.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - SmartPOS ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                min-height: 100vh;
                background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .auth-card {
                width: 100%;
                max-width: 500px;
                border: none;
                border-radius: 24px;
                overflow: hidden;
                box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            }

            .auth-header {
                background: rgba(255,255,255,0.10);
                color: white;
                padding: 28px;
                text-align: center;
            }

            .auth-body {
                background: white;
                padding: 32px;
            }

            .form-floating > .form-control, .form-select {
                border-radius: 14px;
            }

            .btn-auth {
                border-radius: 14px;
                padding: 12px;
                font-weight: 600;
            }

            .welcome-message {
                font-size: 2rem;
                color: black;
                background: rgba(255,255,255,0.7);
                display: inline-block;
                padding: 5px 15px;
                border-radius: 30px;
            }
    </style>
</head>
<body>
    <div class="card auth-card">
        <div class="auth-header">
            <h3>SmartPOS ERP</h3>
            <p class="welcome-message">Create Account</p>
            <p>Register New User</p>
        </div>
        <div class="auth-body">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="form-floating mb-3">
                    <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                    <label asp-for="FullName"></label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email" />
                    <label asp-for="Email"></label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Phone" />
                    <label asp-for="PhoneNumber"></label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <label asp-for="Password"></label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                    <label asp-for="ConfirmPassword"></label>
                </div>
                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select">
                        <option value="">Select Role</option>
                        <option value="Admin">Admin</option>
                        <option value="Manager">Manager</option>
                        <option value="Cashier">Cashier</option>
                    </select>
                </div>
                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-success btn-auth">Register</button>
                </div>
                <div class="text-center">
                    <a asp-action="Login">Already have an account? Login</a>
                </div>
            </form>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>