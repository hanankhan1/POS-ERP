@model POSERP.Models.Account.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - SmartPOS ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
            body {
                min-height: 100vh;
                background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .auth-card {
                width: 100%;
                max-width: 460px;
                border: none;
                border-radius: 24px;
                overflow: hidden;
                box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            }

            .auth-header {
                background: rgba(0,0,0,0.4);
                color: white;
                padding: 28px;
                text-align: center;
            }

                .auth-header h3 {
                    font-weight: 700;
                }

            .welcome-message {
                font-size: 1.8rem;
                font-weight: 600;
                background: white;
                color: #0f172a;
                display: inline-block;
                padding: 5px 20px;
                border-radius: 40px;
                margin: 10px 0;
            }

            .auth-body {
                background: white;
                padding: 32px;
            }

            .form-floating > .form-control, .form-select {
                border-radius: 14px;
                border: 1.5px solid #e2e8f0;
            }

            .btn-auth {
                border-radius: 40px;
                padding: 12px;
                font-weight: 600;
                background: #1e3a8a;
                border: none;
            }

                .btn-auth:hover {
                    background: #2563eb;
                    transform: translateY(-2px);
                }

            .small-link {
                text-decoration: none;
                font-size: 0.85rem;
                color: #3b82f6;
            }
    </style>
</head>
<body>
    <div class="card auth-card">
        <div class="auth-header">
            <i class="fas fa-cash-register fa-2x mb-2"></i>
            <h3>SmartPOS ERP</h3>
            <div class="welcome-message">Welcome Back</div>
            <p class="mb-0 small opacity-75">Sign in to your account</p>
        </div>
        <div class="auth-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email Address" />
                    <label asp-for="Email"><i class="far fa-envelope me-1"></i> Email Address</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <label asp-for="Password"><i class="fas fa-lock me-1"></i> Password</label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-semibold"><i class="fas fa-user-tag"></i> Select Role</label>
                    <select asp-for="Role" class="form-select">
                        <option value="">-- Select Role --</option>
                        <option value="Admin">Admin</option>
                        <option value="Manager">Manager</option>
                        <option value="Cashier">Cashier</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-auth"><i class="fas fa-sign-in-alt me-2"></i> Login</button>
                </div>
                <div class="d-flex justify-content-between">
                    <a asp-action="Register" class="small-link"><i class="fas fa-user-plus"></i> Create Account</a>
                    <a asp-action="ForgotPassword" class="small-link"><i class="fas fa-key"></i> Forgot Password?</a>
                </div>
            </form>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>