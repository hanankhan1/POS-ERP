@model POSERP.Models.Customer.CustomerViewModel
@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Loyalty & Credit";
}

<div class="container mt-3">
    <h2><i class="fas fa-gem"></i> Loyalty & Credit - @Model.FullName</h2>
    <div class="card">
        <div class="card-body">
            <p><strong>Current Loyalty Points:</strong> @Model.LoyaltyPoints</p>
            <p><strong>Current Credit Balance:</strong> $@Model.CreditBalance</p>
            <hr />
            <form method="post" asp-action="UpdateLoyalty">
                <input type="hidden" name="customerId" value="@Model.CustomerID" />
                <div class="mb-3">
                    <label>Add / Subtract Points</label>
                    <input type="number" name="pointsToAdd" class="form-control" value="0" />
                    <small class="text-muted">Use negative value to subtract points.</small>
                </div>
                <div class="mb-3">
                    <label>Add / Subtract Credit ($)</label>
                    <input type="number" step="0.01" name="creditToAdd" class="form-control" value="0" />
                    <small class="text-muted">Use negative value to subtract credit.</small>
                </div>
                <button type="submit" class="btn btn-primary">Update</button>
                <a href="/Customer/CustomerList" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>