@model POSERP.Models.Customer.CustomerPurchaseHistoryViewModel
@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Purchase History - " + Model.CustomerName;
}

<div class="container-fluid px-4 py-3">
    <div class="customer-header">
        <h2><i class="fas fa-history me-2"></i>Purchase History: @Model.CustomerName</h2>
        <p class="mb-0 opacity-75">Loyalty Points: @Model.LoyaltyPoints | Credit Balance: $@Model.CreditBalance.ToString("F2")</p>
    </div>

    @if (!Model.Sales.Any())
    {
        <div class="alert alert-info">No purchases found for this customer.</div>
    }
    else
    {
        foreach (var sale in Model.Sales)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong>Sale #@sale.SaleId</strong>
                        <span>@sale.SaleDate.ToString("yyyy-MM-dd HH:mm")</span>
                        @if (sale.IsCancelled)
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@sale.PaymentStatus</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Total</th></tr>
                            </thead>
                            <tbody>
                                @if (sale.Items != null && sale.Items.Any())
                                {
                                    foreach (var item in sale.Items)
                                    {
                                        <tr>
                                            <td>@item.ProductName</td>
                                            <td>@item.Quantity</td>
                                            <td>$@item.UnitPrice.ToString("F2")</td>
                                            <td>$@item.SubTotal.ToString("F2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-muted">No items found for this sale.</td></tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                    <td>$@((sale.TotalAmount + sale.DiscountAmount - sale.TaxAmount).ToString("F2"))</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end">Discount:</td>
                                    <td>-$@sale.DiscountAmount.ToString("F2")</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end">Tax:</td>
                                    <td>$@sale.TaxAmount.ToString("F2")</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                    <td><strong>$@sale.TotalAmount.ToString("F2")</strong></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end">Payment:</td>
                                    <td>@sale.PaymentMethod</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    <div class="mt-3">
        <a href="/Customer/CustomerList" class="btn btn-secondary">Back to Customer List</a>
    </div>
</div>

<style>
    .customer-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        padding: 1.5rem 2rem;
        border-radius: 1rem;
        color: white;
        margin-bottom: 2rem;
    }
</style>