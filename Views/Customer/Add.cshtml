@model POSERP.Models.Customer.CustomerViewModel
@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Add Customer";
}

<div class="container mt-3">
    <h2><i class="fas fa-user-plus"></i> Add Customer</h2>
    <form method="post" asp-action="Add">
        <div class="mb-3">
            <label>Full Name</label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Phone</label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Address</label>
            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
        </div>
        <div class="mb-3">
            <label>Loyalty Points</label>
            <input asp-for="LoyaltyPoints" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label>Credit Balance ($)</label>
            <input asp-for="CreditBalance" class="form-control" type="number" step="0.01" />
        </div>
        <button type="submit" class="btn btn-success">Save</button>
        <a href="/Customer/CustomerList" class="btn btn-secondary">Cancel</a>
    </form>
</div>