@{
    Layout = "_CashierLayout";
    ViewData["Title"] = "Cashier Dashboard";
}

<div class="container-fluid mt-3">
    <div class="dashboard-header">
        <h2><i class="fas fa-cash-register"></i> Cashier Dashboard</h2>
        <p>Welcome back, @User.Identity.Name</p>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5>Today's Sales</h5>
                    <h3>$@ViewBag.TodaySales.ToString("F2")</h3>
                    <p>@ViewBag.TodayTransactions transactions</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5>Quick Actions</h5>
                    <a href="/POS/Index" class="btn btn-light btn-sm">New Sale</a>
                    <a href="/Cashier/MySales" class="btn btn-light btn-sm">My Sales</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5>Attendance</h5>
                    @if (!ViewBag.HasClockedIn)
                    {
                        <button id="clockInBtn" class="btn btn-light btn-sm">Clock In</button>
                    }
                    else if (!ViewBag.HasClockedOut)
                    {
                        <button id="clockOutBtn" class="btn btn-warning btn-sm">Clock Out</button>
                        <span class="badge bg-light text-dark ms-2">Clocked In</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Completed</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#clockInBtn').click(function() {
            $.post('/Cashier/ClockIn', function(res) {
                alert(res.message);
                if (res.success) location.reload();
            });
        });
        $('#clockOutBtn').click(function() {
            $.post('/Cashier/ClockOut', function(res) {
                alert(res.message);
                if (res.success) location.reload();
            });
        });
    </script>
}