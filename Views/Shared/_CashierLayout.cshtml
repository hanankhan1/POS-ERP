<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SmartPOS ERP (Cashier)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <style>
        body {
        background: #f4f7fc;
        font-family: 'Inter', system-ui, sans-serif;
        }

        .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100%;
        width: 260px;
        background: #0f172a;
        color: white;
        z-index: 1000;
        overflow-y: auto;
        }

        .sidebar-header {
        padding: 1.5rem;
        text-align: center;
        border-bottom: 1px solid #1e293b;
        }

        .sidebar-nav {
        list-style: none;
        padding: 0;
        margin: 0;
        }

        .sidebar-nav li a {
        display: block;
        padding: 12px 20px;
        color: #e2e8f0;
        text-decoration: none;
        border-left: 3px solid transparent;
        }

        .sidebar-nav li a:hover {
        background: #1e293b;
        border-left-color: #3b82f6;
        color: white;
        }

        .sidebar-nav li a i {
        width: 28px;
        margin-right: 10px;
        }

        .main-content {
        margin-left: 260px;
        padding: 20px;
        }

        @@media (max-width: 768px) {
        .sidebar {
        display: none;
        }

        .main-content {
        margin-left: 0;
        }
        }

        .dashboard-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        color: white;
        margin-bottom: 2rem;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <i class="fas fa-cash-register fa-2x mb-2"></i>
            <h4>SmartPOS ERP</h4>
            <p>Cashier Panel</p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/Cashier/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
            <li><a href="/POS/Index"><i class="fas fa-cash-register"></i> Point of Sale</a></li>
            <li><a href="/Cashier/MySales"><i class="fas fa-history"></i> My Sales</a></li>
            <li><a asp-controller="Account" asp-action="Logout" class="text-danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
    </div>
    <div class="main-content">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>