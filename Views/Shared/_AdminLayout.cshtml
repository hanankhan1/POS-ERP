﻿@{
var salesLabels = ViewBag.SalesLabels as List<string> ?? new List<string>();
var salesValues = ViewBag.SalesValues as List<decimal> ?? new List<decimal>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SmartPOS ERP</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        background: #f4f7fc;
        font-family: 'Inter', system-ui, sans-serif;
        overflow-x: hidden;
        }

        /* Sidebar styles */
        .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100%;
        width: 260px;
        background: #0f172a;
        color: white;
        z-index: 1000;
        overflow-y: auto;
        }

        .sidebar-header {
        padding: 1.5rem;
        text-align: center;
        border-bottom: 1px solid #1e293b;
        }

        .sidebar-header h4 {
        font-size: 1.2rem;
        font-weight: 600;
        }

        .sidebar-nav {
        list-style: none;
        padding: 0;
        margin: 0;
        }

        .sidebar-nav li a {
        display: block;
        padding: 12px 20px;
        color: #e2e8f0;
        text-decoration: none;
        border-left: 3px solid transparent;
        }

        .sidebar-nav li a:hover {
        background: #1e293b;
        border-left-color: #3b82f6;
        color: white;
        }

        .sidebar-nav li a i {
        width: 28px;
        margin-right: 10px;
        }

        .sub-menu {
        list-style: none;
        padding-left: 48px;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
        background: #0a0f1c;
        }

        .sidebar-nav li:hover .sub-menu {
        max-height: 300px;
        }

        .sub-menu li a {
        padding: 8px 20px;
        font-size: 0.85rem;
        }

        /* Main content */
        .main-content {
        margin-left: 260px;
        padding: 20px;
        }

        @@media (max-width: 768px) {
        .sidebar {
        width: 0;
        display: none;
        }

        .main-content {
        margin-left: 0;
        }
        }

        /* Dashboard card styles (keep from your original) */
        .dashboard-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        padding: 1.5rem 2rem;
        border-radius: 0 0 1.5rem 1.5rem;
        color: white;
        margin-bottom: 2rem;
        }

        .stat-card {
        border: none;
        border-radius: 1.25rem;
        transition: transform 0.2s;
        overflow: hidden;
        }

        .stat-card:hover {
        transform: translateY(-5px);
        }

        .stat-icon {
        font-size: 2rem;
        opacity: 0.3;
        position: absolute;
        bottom: 0.5rem;
        right: 0.75rem;
        }

        .card-title {
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: 600;
        }

        .stat-value {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0;
        }

        .chart-card, .recent-orders-card {
        border: none;
        border-radius: 1.25rem;
        background: white;
        }

        .badge-status {
        padding: 0.35rem 0.65rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        }

        .bg-soft-success {
        background-color: #d1fae5;
        color: #065f46;
        }

        .bg-soft-warning {
        background-color: #fed7aa;
        color: #92400e;
        }

        footer {
        text-align: center;
        margin-top: 2rem;
        color: #6c757d;
        font-size: 0.8rem;
        }

        .clock-buttons {
        display: flex;
        gap: 10px;
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <i class="fas fa-chalkboard-user fa-2x mb-2"></i>
            <h4>SmartPOS ERP</h4>
            <p>Admin Panel</p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/Admin/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
            <li>
                <a href="#"><i class="fas fa-box"></i> Products</a>
                <ul class="sub-menu">
                    <li><a href="/Product/Product">All Products</a></li>
                    <li><a href="/Product/Add">Add Product</a></li>
                    <li><a href="/Product/Categories">Categories</a></li>
                    <li><a href="/Product/StockAlerts">Stock Alerts</a></li>
                </ul>
            </li>
            <li>
                <a href="#"><i class="fas fa-warehouse"></i> Inventory</a>
                <ul class="sub-menu">
                    <li><a href="/Inventory/StockLevels">Stock Levels</a></li>
                    <li><a href="/Inventory/StockTransfers">Stock Transfers</a></li>
                    <li><a href="/Inventory/StockLevels">Adjustments</a></li>   <!-- fixed: points to StockLevels where adjustments are done -->
                    <li><a href="/Inventory/InventoryHistory"><i class="fas fa-history"></i> Inventory Logs</a></li>
                </ul>

                <a href="#"><i class="fas fa-users"></i> Customers</a>
                <ul class="sub-menu">
                    <li><a href="/Customer/CustomerList">Customer List</a></li>
                    <li><a href="/Customer/Add">Add Customer</a></li>
                    <!-- <li><a href="/Customer/Loyalty">Loyalty Program</a></li>optional, you can remove if not needed -->
                </ul>
            </li>
            <li>
                <a href="#"><i class="fas fa-truck"></i> Suppliers</a>
                <ul class="sub-menu">
                    <li><a href="/Supplier/Index">Supplier List</a></li>
                    <li><a href="/Supplier/AddSupplier">Add Supplier</a></li>
                </ul>
            </li>
            <li><a href="/Purchase/Index"><i class="fas fa-shopping-cart"></i> Purchases</a></li>

            <li>
                <a href="#"><i class="fas fa-user-tie"></i> Employees</a>
                <ul class="sub-menu">
                    <li><a href="/Employee/EmployeeList">Employee List</a></li>
                    <li><a href="/Employee/AttendanceReport">Attendance Report</a></li>
                    <li><a href="/Employee/Payroll">Payroll</a></li>
                    <li><a href="/Employee/Performance">Performance</a></li>
                </ul>
            </li>

            <li>
                <li>
                    <a href="#"><i class="fas fa-calendar-check"></i> Attendance</a>
                    <ul class="sub-menu">
                        <li><a href="/Employee/ManageAttendance">Manage Attendance</a></li>
                        <li><a href="/Employee/AttendanceReport">Attendance Report</a></li>
                    </ul>
                </li>
              
                <li>
                    <a href="#"><i class="fas fa-chart-bar"></i> Reports</a>
                    <ul class="sub-menu">
                        <li><a href="/Reports/SalesReport">Sales Report</a></li>
                        <li><a href="/Reports/ProfitReport">Profit Report</a></li>
                        <li><a href="/Reports/InventoryReport">Inventory Report</a></li>
                        <li><a href="/Reports/DashboardSummary">Report Dashboard</a></li>
                        <li><a href="/Reports/ExpenseReport"><i class="fas fa-dollar-sign"></i> Expense Report</a></li>
                    </ul>
                </li>
                <li><a href="/FraudDetection/Index"><i class="fas fa-shield-alt"></i> Fraud Alerts</a></li>
                <li><a href="/Prediction/Index"><i class="fas fa-chart-line"></i> Demand Forecast</a></li>
                <li><a href="/OfflineSync/Status"><i class="fas fa-sync-alt"></i> Offline Sync</a></li>

                <li style="margin-top: 2rem;">
                    <a asp-controller="Account" asp-action="Logout" class="text-danger">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main content -->
        <div class="main-content">
            @RenderBody()
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>