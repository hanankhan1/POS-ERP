@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ManagerLayout";
    }
    ViewData["Title"] = "Edit Product";
    var product = Model as dynamic;
}

<div class="container">
    <h2 class="mt-3">Edit Product</h2>

    <form method="post" action="/Product/Edit/@product.ProductID">
        @Html.AntiForgeryToken()

        <input type="hidden" name="ProductID" value="@product.ProductID" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Product Name</label>
                <input type="text" name="ProductName" class="form-control" value="@product.ProductName" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Barcode</label>
                <input type="text" name="Barcode" class="form-control" value="@product.Barcode" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Category</label>
                <select name="CategoryID" class="form-select" required>
                    <option value="">-- Select --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        if (cat.CategoryID == product.CategoryID)
                        {
                            <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label>Supplier</label>
                <select name="SupplierID" class="form-select" required>
                    <option value="">-- Select --</option>
                    @foreach (var sup in ViewBag.Suppliers)
                    {
                        if (sup.SupplierID == product.SupplierID)
                        {
                            <option value="@sup.SupplierID" selected>@sup.SupplierName</option>
                        }
                        else
                        {
                            <option value="@sup.SupplierID">@sup.SupplierName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label>Cost Price</label>
                <input type="number" step="0.01" name="CostPrice" class="form-control" value="@product.CostPrice" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Selling Price</label>
                <input type="number" step="0.01" name="SellingPrice" class="form-control" value="@product.SellingPrice" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Reorder Level</label>
                <input type="number" name="ReorderLevel" class="form-control" value="@product.ReorderLevel" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Unit (e.g., pcs, kg, bottle)</label>
                <input type="text" name="Unit" class="form-control" value="@product.Unit" />
            </div>
            <div class="col-md-6 mb-3">
                <label>Status</label>
                <select name="Status" class="form-select">
                    <option value="Available" selected="@(product.Status == "Available" ? "selected" : null)">Available</option>
                    <option value="Discontinued" selected="@(product.Status == "Discontinued" ? "selected" : null)">Discontinued</option>
                </select>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Update Product</button>
        <a href="/Product/Product" class="btn btn-secondary">Cancel</a>
    </form>
</div>